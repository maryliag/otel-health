# Copy this file to .env and fill in your values

# GitHub token — same as local (required scope: read:org)
GITHUB_TOKEN=ghp_your_token_here

# Grafana Cloud OTLP endpoint (for pushing metrics)
# Find this in Grafana Cloud → your stack → OpenTelemetry → Configure
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Grafana Cloud instance ID (numeric, used for OTLP auth)
GRAFANA_CLOUD_INSTANCE_ID=123456

# Grafana Cloud API key (needs MetricsPublisher + Editor roles)
GRAFANA_CLOUD_API_KEY=glsa_your_key_here

# Grafana Cloud instance URL (for dashboard provisioning)
GRAFANA_CLOUD_URL=https://your-instance.grafana.net

# Prometheus datasource UID (optional — skips auto-discovery)
# Find it in Grafana Cloud → Connections → Data sources → click Prometheus → UID is in the URL
GRAFANA_CLOUD_PROM_UID=
